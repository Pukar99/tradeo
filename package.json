{
  "name": "tradeo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth": "playwright test tests/e2e/auth.spec.js",
    "test:e2e:trade": "playwright test tests/e2e/trade-flow.spec.js",
    "test:e2e:report": "playwright show-report",
    "test:perf": "k6 run tests/perf/load.js",
    "test:perf:burst": "k6 run --env SCENARIO=concurrent_burst tests/perf/load.js",
    "test:ci": "vitest run --coverage && playwright test --reporter=list"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "axios": "^1.14.0",
    "lightweight-charts": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
